{
  "manifest_version": 3,
  "name": "PVE Paste Helper",
  "version": "1.0.0",
  "description": "Paste text and saved snippets into PVE (Proxmox VE) noVNC VM consoles using your normal paste shortcut or a floating panel.",
  "permissions": ["clipboardRead", "storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PVE Paste Helper",
    "default_popup": "popup.html"
  }
}
